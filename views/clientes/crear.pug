extends ../layout

block contenido
    h1 Registrar Nuevo Cliente

    if error
        span.error-msg= error

    form(action="/clientes/nuevo" method="POST")
        div
            label(for="id") ID de Cliente (Manual):
            input(type="number" name="id", required=true, placeholder="Ej: 1")
        
        div
            label(for="tipoDoc") Tipo de Documento:
            select(name="tipoDoc")
                option(value="DNI" selected=datos && datos.tipoDoc === "DNI") DNI
                option(value="CUIT" selected=datos && datos.tipoDoc === "CUIT") CUIT

        div
            label(for="nroDoc") Número de Documento:
            input(type="text" name="nroDoc", required=true, value=datos ? datos.nroDoc : '', placeholder="Ej: 32456789")

        div
            label(for="nombre") Nombre (si es DNI):
            input(type="text" name="nombre", value=datos ? datos.nombre : '')

        div
            label(for="razonSocial") Razón Social (si es CUIT):
            input(type="text" name="razonSocial", value=datos ? datos.razonSocial : '')

        div
            label(for="email") Email:
            input(type="email" name="email", required=true, value=datos ? datos.email : '')

        div
            label(for="telefono") Teléfono:
            input(type="text" name="telefono", value=datos ? datos.telefono : '')

        div
            label(for="direccion") Dirección:
            input(type="text" name="direccion", value=datos ? datos.direccion : '')

        div.form-actions
            button(type="submit").btn-guardar Registrar Cliente
            a(href="/clientes").btn-cancelar Cancelar